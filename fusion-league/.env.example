# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WarcraftLogs
WCL_CLIENT_ID=your-wcl-client-id
WCL_CLIENT_SECRET=your-wcl-client-secret

# Discord OAuth (configured in Supabase dashboard, but store for reference)
# DISCORD_CLIENT_ID=your-discord-client-id
# DISCORD_CLIENT_SECRET=your-discord-client-secret

# Discord Bot (for role checking)
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_SERVER_ID=your-discord-server-id

# App
ORIGIN=http://localhost:5173
PICKS_OPEN_HOUR=8   # 8am EST
PICKS_CLOSE_HOUR=20 # 8pm EST
